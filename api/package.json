{
  "name": "eaglebox-cricket-api",
  "version": "2.0.0",
  "description": "Eagle Box Cricket Management System — REST API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "predev": "node -e \"const net=require('net');const s=net.createServer();s.listen(5001,()=>s.close());s.on('error',()=>{try{require('child_process').execSync('powershell -Command \\\"Stop-Process -Id (Get-NetTCPConnection -LocalPort 5001).OwningProcess -Force\\\"',{stdio:'ignore'})}catch(e){}})\"",
    "migrate": "node src/config/migrate.js",
    "seed": "node src/config/seed.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "joi": "^17.13.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "nodemailer": "^6.10.1",
    "pg": "^8.11.5",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.6",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.3"
  }
}
